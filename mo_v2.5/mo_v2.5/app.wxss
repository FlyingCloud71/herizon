page {
  min-height: 100%;
  background: linear-gradient(180deg, #f7f1e8 0%, #fbf7ef 48%, #f4eadf 100%);
  color: #343331;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

view,
text,
button {
  box-sizing: border-box;
  overflow-wrap: break-word;
}

.page {
  min-height: 100vh;
  padding: 34rpx 28rpx 60rpx;
}

.eyebrow {
  color: #8a6b4d;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.title {
  margin-top: 12rpx;
  color: #2f2d2a;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.16;
}

.subtitle {
  margin-top: 18rpx;
  color: #4f4a44;
  font-size: 29rpx;
  line-height: 1.6;
}

.panel {
  margin-top: 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(191, 164, 139, 0.72);
  border-radius: 8rpx;
  background-color: rgba(255, 250, 242, 0.74);
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.54) 1rpx, transparent 1.6rpx);
  background-size: 11rpx 11rpx;
  -webkit-backdrop-filter: blur(38rpx) saturate(1.45);
  backdrop-filter: blur(38rpx) saturate(1.45);
  box-shadow: 0 18rpx 44rpx rgba(92, 71, 52, 0.1);
}

.section-title {
  color: #343331;
  font-size: 32rpx;
  font-weight: 800;
}

.muted {
  color: #5f5850;
  font-size: 26rpx;
  line-height: 1.5;
}

.primary-btn,
.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  padding: 18rpx 24rpx;
  margin-top: 28rpx;
  border-radius: 8rpx;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.28;
  box-shadow: none;
}

.primary-btn {
  background: #ffd0a6;
  color: #6b4a37;
  box-shadow: 0 16rpx 30rpx rgba(255, 208, 166, 0.32);
}

.secondary-btn {
  border: 1rpx solid rgba(177, 135, 102, 0.78);
  background-color: rgba(255, 250, 242, 0.72);
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.48) 1rpx, transparent 1.6rpx);
  background-size: 11rpx 11rpx;
  -webkit-backdrop-filter: blur(30rpx) saturate(1.35);
  backdrop-filter: blur(30rpx) saturate(1.35);
  color: #7a4b2f;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f0e4d2;
  color: #735f4b;
  font-size: 24rpx;
  font-weight: 700;
}

.danger {
  color: #b86a5b;
}

.warn {
  color: #a76d36;
}

.ok {
  color: #6f8e91;
}

