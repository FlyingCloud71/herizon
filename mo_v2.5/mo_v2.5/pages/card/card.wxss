.slow-card {
  margin-top: 30rpx;
  padding: 30rpx;
  border-radius: 8rpx;
  background-color: rgba(255, 250, 242, 0.74);
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.55) 1rpx, transparent 1.6rpx);
  background-size: 11rpx 11rpx;
  border: 1rpx solid rgba(238, 222, 203, 0.86);
  -webkit-backdrop-filter: blur(38rpx) saturate(1.45);
  backdrop-filter: blur(38rpx) saturate(1.45);
  box-shadow: 0 20rpx 48rpx rgba(92, 71, 52, 0.12);
}

.card-top {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.card-top > view:first-child {
  flex: 1;
  min-width: 0;
}

.card-kicker {
  color: #8a6b4d;
  font-size: 24rpx;
  font-weight: 800;
}

.card-title {
  margin-top: 10rpx;
  color: #343331;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.18;
}

.card-level {
  flex: 0 0 auto;
  min-height: 58rpx;
  padding: 12rpx 18rpx;
  border-radius: 8rpx;
  background: #e7f0ec;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.25;
}

.comfort-line {
  margin-top: 26rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background-color: rgba(238, 248, 241, 0.58);
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.42) 1rpx, transparent 1.6rpx);
  background-size: 10rpx 10rpx;
  -webkit-backdrop-filter: blur(24rpx) saturate(1.3);
  backdrop-filter: blur(24rpx) saturate(1.3);
  color: #4c4a46;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.45;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 24rpx;
}

.info-item {
  min-height: 126rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background-color: rgba(244, 250, 245, 0.62);
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.44) 1rpx, transparent 1.6rpx);
  background-size: 10rpx 10rpx;
  -webkit-backdrop-filter: blur(24rpx) saturate(1.3);
  backdrop-filter: blur(24rpx) saturate(1.3);
}

.info-label,
.info-value {
  display: block;
}

.info-label {
  color: #82776b;
  font-size: 22rpx;
  font-weight: 700;
}

.info-value {
  margin-top: 10rpx;
  color: #343331;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.card-section {
  margin-top: 28rpx;
}

.card-section-title {
  color: #343331;
  font-size: 30rpx;
  font-weight: 900;
}

.mini-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.mini-tag {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #f0e4d2;
  color: #735f4b;
  font-size: 24rpx;
  font-weight: 700;
}

.soft-note {
  margin-top: 12rpx;
  color: #7a726b;
  font-size: 26rpx;
  line-height: 1.45;
}

.follow-panel,
.trip-entry {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(238, 222, 203, 0.86);
  background-color: rgba(255, 250, 242, 0.74);
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.55) 1rpx, transparent 1.6rpx);
  background-size: 11rpx 11rpx;
  -webkit-backdrop-filter: blur(38rpx) saturate(1.45);
  backdrop-filter: blur(38rpx) saturate(1.45);
  box-shadow: 0 18rpx 44rpx rgba(92, 71, 52, 0.1);
}

.trip-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20rpx;
}

.trip-entry > view:first-child {
  flex: 1;
  min-width: 0;
}

.trip-entry-action {
  flex: 0 0 auto;
  min-width: 88rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: #ffd0a6;
  color: #6b4a37;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
}

.follow-subtitle {
  margin-top: 10rpx;
  color: #7a726b;
  font-size: 25rpx;
  line-height: 1.45;
}

.date-picker,
.field-block,
.reminder-row {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background-color: rgba(244, 250, 245, 0.62);
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.44) 1rpx, transparent 1.6rpx);
  background-size: 10rpx 10rpx;
}

.date-picker,
.reminder-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 18rpx;
}

.date-label,
.field-label,
.reminder-title {
  color: #343331;
  font-size: 27rpx;
  font-weight: 800;
}

.date-value,
.date-placeholder {
  flex: 0 1 auto;
  font-size: 27rpx;
  font-weight: 800;
}

.date-value {
  color: #d8793f;
}

.date-placeholder,
.input-placeholder {
  color: #8ca39a;
}

.reminder-desc {
  margin-top: 6rpx;
  color: #7a726b;
  font-size: 24rpx;
  line-height: 1.35;
}

.number-input {
  height: 70rpx;
  margin-top: 10rpx;
  color: #343331;
  font-size: 30rpx;
  font-weight: 800;
}

.feedback-textarea {
  width: 100%;
  min-height: 148rpx;
  margin-top: 12rpx;
  color: #343331;
  font-size: 27rpx;
  line-height: 1.45;
}

.compact-btn {
  min-height: 78rpx;
  margin-top: 20rpx;
  font-size: 28rpx;
}

.saved-note {
  margin-top: 14rpx;
  color: #8a6b4d;
  font-size: 24rpx;
  line-height: 1.45;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  padding: 28rpx;
  background: rgba(52, 51, 49, 0.22);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.trip-modal {
  width: 100%;
  padding: 30rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(238, 222, 203, 0.9);
  background-color: rgba(255, 250, 242, 0.82);
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.56) 1rpx, transparent 1.6rpx);
  background-size: 11rpx 11rpx;
  -webkit-backdrop-filter: blur(46rpx) saturate(1.5);
  backdrop-filter: blur(46rpx) saturate(1.5);
  box-shadow: 0 24rpx 60rpx rgba(92, 71, 52, 0.18);
}

.modal-top,
.modal-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.modal-top > view:first-child {
  flex: 1;
  min-width: 0;
}

.modal-top {
  align-items: flex-start;
  justify-content: space-between;
}

.modal-close {
  flex: 0 0 auto;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(245, 235, 221, 0.84);
  color: #8a6b4d;
  font-size: 38rpx;
  line-height: 52rpx;
  text-align: center;
}

.modal-actions {
  margin-top: 22rpx;
}

.modal-btn {
  flex: 1 1 220rpx;
  min-height: 80rpx;
  margin-top: 0;
  font-size: 27rpx;
}
