.feedback-card {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(238, 222, 203, 0.86);
  background-color: rgba(255, 250, 242, 0.74);
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.55) 1rpx, transparent 1.6rpx);
  background-size: 11rpx 11rpx;
  -webkit-backdrop-filter: blur(38rpx) saturate(1.45);
  backdrop-filter: blur(38rpx) saturate(1.45);
  box-shadow: 0 18rpx 44rpx rgba(92, 71, 52, 0.1);
}

.question-block {
  margin-top: 28rpx;
}

.question-block:first-child {
  margin-top: 0;
}

.question-title {
  color: #343331;
  font-size: 32rpx;
  font-weight: 900;
}

.choice-row {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 16rpx;
}

.choice {
  min-height: 86rpx;
  padding: 22rpx 24rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(224, 202, 180, 0.88);
  background-color: rgba(244, 250, 245, 0.62);
  color: #4c4a46;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.choice.active {
  border-color: #ffd0a6;
  background: rgba(255, 208, 166, 0.38);
  color: #343331;
}

.field-block {
  margin-top: 28rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background-color: rgba(244, 250, 245, 0.62);
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.44) 1rpx, transparent 1.6rpx);
  background-size: 10rpx 10rpx;
}

.field-label {
  color: #343331;
  font-size: 30rpx;
  font-weight: 900;
}

.feedback-textarea {
  width: 100%;
  min-height: 180rpx;
  margin-top: 14rpx;
  color: #343331;
  font-size: 30rpx;
  line-height: 1.45;
}
