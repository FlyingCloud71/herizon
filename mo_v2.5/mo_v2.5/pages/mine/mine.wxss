.empty-history,
.history-card {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(238, 222, 203, 0.86);
  background-color: rgba(255, 250, 242, 0.74);
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.55) 1rpx, transparent 1.6rpx);
  background-size: 11rpx 11rpx;
  -webkit-backdrop-filter: blur(38rpx) saturate(1.45);
  backdrop-filter: blur(38rpx) saturate(1.45);
  box-shadow: 0 18rpx 44rpx rgba(92, 71, 52, 0.1);
}

.empty-title,
.history-name {
  color: #343331;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.empty-desc,
.history-meta,
.history-note {
  margin-top: 12rpx;
  color: #7a726b;
  font-size: 27rpx;
  line-height: 1.45;
}

.history-top,
.history-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-top {
  align-items: flex-start;
  justify-content: space-between;
}

.history-top > view:first-child {
  flex: 1;
  min-width: 0;
}

.history-level {
  flex: 0 0 auto;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  background: #e7f0ec;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.25;
}

.history-actions {
  margin-top: 22rpx;
}

.history-btn {
  flex: 1 1 220rpx;
  min-height: 78rpx;
  margin-top: 0;
  font-size: 27rpx;
}
