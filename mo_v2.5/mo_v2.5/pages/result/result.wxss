.result-box {
  margin-top: 30rpx;
  padding: 30rpx;
  border-radius: 8rpx;
  background-color: rgba(255, 250, 242, 0.74);
  background-image: radial-gradient(circle, rgba(255, 255, 255, 0.55) 1rpx, transparent 1.6rpx);
  background-size: 11rpx 11rpx;
  border: 1rpx solid rgba(238, 222, 203, 0.86);
  -webkit-backdrop-filter: blur(38rpx) saturate(1.45);
  backdrop-filter: blur(38rpx) saturate(1.45);
  box-shadow: 0 18rpx 44rpx rgba(92, 71, 52, 0.1);
}

.result-box.ok {
  border-color: #9eb9b5;
  background-color: rgba(239, 246, 243, 0.72);
}

.result-box.warn {
  border-color: #d7b77a;
  background-color: rgba(250, 239, 219, 0.72);
}

.result-box.danger {
  border-color: #d9aaa1;
  background-color: rgba(248, 226, 221, 0.74);
}

.level {
  font-size: 38rpx;
  font-weight: 900;
}

.score {
  margin-top: 10rpx;
  color: #343331;
  font-size: 86rpx;
  font-weight: 900;
  line-height: 1;
}

.score-label {
  margin-top: 8rpx;
  color: #7a726b;
  font-size: 25rpx;
}

.bullet {
  margin-top: 18rpx;
  padding-left: 22rpx;
  border-left: 6rpx solid #9eb9b5;
  color: #4c4a46;
  font-size: 27rpx;
  line-height: 1.45;
}

.warn-text {
  border-left-color: #d8793f;
}

.plan-meta {
  margin-top: 16rpx;
  color: #9b623e;
  font-size: 27rpx;
  font-weight: 800;
}

.point-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 20rpx;
}

.point-label {
  flex: 0 0 116rpx;
  color: #9b623e;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.45;
}

.point-text {
  flex: 1;
  min-width: 0;
  color: #343331;
  font-size: 28rpx;
  line-height: 1.45;
}
